{
  "name": "hidden-whisper-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:server:watch": "node --watch server/index.js",
