# Hidden Whisper gateway configuration

# HTTP server
HOST=0.0.0.0
PORT=3000
WS_PATH=/ws

# Tor SOCKS proxy (Tor should be running on this machine)
TOR_ENABLED=true
TOR_SOCKS_HOST=127.0.0.1
TOR_SOCKS_PORT=9050

# Default IRC server (onion) + connection options
IRC_HOST=examplehiddenservice.onion
IRC_PORT=6667
IRC_TLS=false
IRC_TLS_REJECT_UNAUTHORIZED=true

# Optional: require a token to use the gateway
# If set, pass it to the UI via URL: https://your-site/?token=YOUR_TOKEN
# APP_ACCESS_TOKEN=change-me

# Optional: allow the UI to override IRC_HOST/IRC_PORT/IRC_TLS per session.
# Recommended only together with APP_ACCESS_TOKEN.
ALLOW_CLIENT_IRC_SETTINGS=false

# Limits
MAX_TEXT_LEN=900
MAX_NICK_LEN=24
